$ = {:}Diagram

struct Diagram {
    delimiters: ?Delimiters,
    label: ?bytes,
    alignment: ?Alignment,
    body: []Node,

    union Delimiters {
        pipes,
        directional,
    }

    union Alignment {
        left,
        center,
        right,
    }
}

union Node {
    /// Represents literal text.
    terminal: bytes,
    /// Represents an instruction or another production.
    non_terminal: bytes,
    /// Same as `non_terminal`, but it also includes a small label on top,
    /// useful for lightweight notation of a single node. See `group` for
    /// giving a label to a group of nodes.
    label: Label,
    /// A comment.
    comment: bytes,
    /// An empty line.
    skip,
    /// Like concatenation in a regex.
    sequence: []Node,
    /// Identical to a Sequence, but the items are stacked vertically
    /// rather than horizontally.
    ///
    /// Best used when a simple Sequence would be too wide; instead, you
    /// can break the items up into a Stack of Sequences of an appropriate
    /// width.
    stack: []Node,
    /// A Sequence where every item is individually optional, but at least
    /// one item must be chosen
    ///optional_sequence: []Node,
    /// Like | in a regex, puts the first item to the straight line.
    choice: []Node,
    /// Same as `choice` but it puts the center element in the straight line.
    /// Requires an odd number of items, use `choice_index` when dealing with
    /// an even number.
    choice_middle: []Node,
    /// Same as 'choice', but it puts the last element on the straight line.
    /// Use `choice_index` for more fine-grained control over element positioning.
    choice_last: []Node,
    /// Identical to Choice, but the items are stacked horizontally rather
    /// than vertically. There's no "straight-line" choice, so it just
    /// takes a list of children. Best used when a simple Choice would be
    /// too tall; instead, you can break up the items into a
    /// HorizontalChoice of Choices of an appropriate height.
    choice_horizontal: []Node,
    /// Like | in a regex, takes an index for more fine-grainded control
    /// of item positioning.
    choice_index: ChoiceIndex,
    /// Like `||` in a CSS grammar; it's similar to a `choice_index`, but more
    /// than one branch can be taken.
    multiple_choice_any: ChoiceIndex,
    /// Like `&&` in a CSS grammar; it's similar to a `choice_index`, but all
    /// branches must be taken at least once.
    multiple_choice_all: ChoiceIndex,
    /// Like `+` in a regex. The repeat argument is optional, and specifies
    /// something that must go between the repetitions (usually a
    /// `.comment`, but sometimes things like `.terminal(",")`, etc.)
    one_or_more: OneOrMore,
    /// Highlights its child with a dashed outline, and optionally labels it.
    group: Group,

    struct Label {
        label: bytes,
        item: Node,
    }

    struct ChoiceIndex {
        /// Specifies which child is the "normal" choice and should go in
        /// the middle.
        index: int,
        items: []Node,
    }

    struct ZeroOrMore {
        item: Node,
        repeat: ?Node,
    }

    struct OneOrMore {
        item: Node,
        repeat: ?Node,
    }

    struct Group {
        label: ?bytes,
        item: Node,
    }
}
